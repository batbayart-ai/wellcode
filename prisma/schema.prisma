generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

// ─── SITE SETTINGS ──────────────────────────────────────

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─── BANNER / HERO ──────────────────────────────────────

model Banner {
  id           String   @id @default(cuid())
  title        String
  subtitle     String?
  ctaText      String?
  ctaUrl       String?
  imageUrl     String
  imageAlt     String   @default("")
  isActive     Boolean  @default(false)
  sortOrder    Int      @default(0)
  cloudinaryId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── CATEGORIES ─────────────────────────────────────────

model Category {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  type        CategoryType
  description String?
  imageUrl    String?
  products    Product[]
  posts       BlogPost[]
  createdAt   DateTime     @default(now())

  @@index([slug])
  @@index([type])
}

enum CategoryType {
  PRODUCT
  BLOG
}

// ─── PRODUCTS ───────────────────────────────────────────

model Product {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  description    String         @db.Text
  price          Decimal        @db.Decimal(10, 2)
  comparePrice   Decimal?       @db.Decimal(10, 2)
  stockQty       Int            @default(0)
  sku            String?        @unique
  isActive       Boolean        @default(true)
  isFeatured     Boolean        @default(false)
  categories     Category[]
  images         ProductImage[]
  orderItems     OrderItem[]
  tags           String[]
  metadata       Json?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([isFeatured])
}

model ProductImage {
  id           String  @id @default(cuid())
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url          String
  altText      String  @default("")
  sortOrder    Int     @default(0)
  cloudinaryId String?

  @@index([productId])
}

// ─── BLOG ───────────────────────────────────────────────

model BlogPost {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  excerpt        String?
  content        String     @db.Text
  coverImageUrl  String?
  coverImageAlt  String     @default("")
  coverCloudinaryId String?
  isPublished    Boolean    @default(false)
  publishedAt    DateTime?
  categories     Category[]
  tags           String[]
  readingTime    Int?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([slug])
  @@index([isPublished, publishedAt])
}

// ─── SHIPPING METHODS ───────────────────────────────────

model ShippingMethod {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  carrier     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// ─── PAYMENT METHODS ────────────────────────────────────

model PaymentMethod {
  id           String      @id @default(cuid())
  name         String
  description  String?
  type         PaymentType
  extraCharge  Decimal     @db.Decimal(10, 2) @default(0)
  isActive     Boolean     @default(true)
  sortOrder    Int         @default(0)
  instructions String?     @db.Text
  orders       Order[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([isActive])
}

enum PaymentType {
  STRIPE
  BANK_TRANSFER
  CASH_ON_DELIVERY
  OTHER
}

// ─── ORDERS ─────────────────────────────────────────────

model Order {
  id                    String          @id @default(cuid())
  orderNumber           String          @unique @default(cuid())
  status                OrderStatus     @default(PENDING)
  stripeSessionId       String?         @unique
  stripePaymentIntentId String?         @unique
  customerEmail         String
  customerName          String
  customerPhone         String?
  shippingAddress       Json
  subtotal              Decimal         @db.Decimal(10, 2)
  shippingCost          Decimal         @db.Decimal(10, 2) @default(0)
  paymentExtraCharge    Decimal         @db.Decimal(10, 2) @default(0)
  tax                   Decimal         @db.Decimal(10, 2) @default(0)
  total                 Decimal         @db.Decimal(10, 2)
  currency              String          @default("czk")
  notes                 String?
  items                 OrderItem[]
  shippingMethodId      String?
  shippingMethod        ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  paymentMethodId       String?
  paymentMethod         PaymentMethod?  @relation(fields: [paymentMethodId], references: [id])
  packetaPointId        String?
  packetaPointName      String?
  packetaPointAddress   String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([status])
  @@index([customerEmail])
  @@index([stripeSessionId])
  @@index([createdAt])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  productName  String
  productImage String?
  quantity     Int
  unitPrice    Decimal @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
